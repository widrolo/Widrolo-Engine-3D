        <mxCell id="QZozGhfnKPgpjbq-TObu-18" edge="1" parent="1" source="Rupf-1fVi9H6Zibw66AW-23" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="940" y="800" />
            </Array>
            <mxPoint x="940" y="800" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="Rupf-1fVi9H6Zibw66AW-23" parent="1" style="swimlane;startSize=40;" value="System Abstraction" vertex="1">
          <mxGeometry height="280" width="800" x="25" y="680" as="geometry">
            <mxRectangle height="30" width="90" x="140" y="640" as="alternateBounds" />
          </mxGeometry>
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-2" parent="Rupf-1fVi9H6Zibw66AW-23" style="swimlane;" value="Memory" vertex="1">
          <mxGeometry height="200" width="200" y="80" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-3" parent="-NolNCKCxvoOFp3M2r7I-2" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div align=&quot;center&quot;&gt;The memory system acts as a&amp;nbsp;&lt;/div&gt;middleman before any memory allocation. It does not act as a malloc replacement, but rather as a memory allocation tracker. It is able to give out semi reliable memory usage statistics." vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-4" parent="Rupf-1fVi9H6Zibw66AW-23" style="swimlane;" value="Iris" vertex="1">
          <mxGeometry height="200" width="200" x="200" y="80" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-5" parent="-NolNCKCxvoOFp3M2r7I-4" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;Iris is a GPU abstraction layer, meant to both simplify GPU operations, as well as being generally API agnostic.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Any engine handler or component can easily access Iris to perform tasks on the GPU.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-6" parent="Rupf-1fVi9H6Zibw66AW-23" style="swimlane;" value="OS" vertex="1">
          <mxGeometry height="200" width="200" x="400" y="80" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-7" parent="-NolNCKCxvoOFp3M2r7I-6" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;OS is an abstraction layer for accessing OS components such as file system or process manipulation.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Its primary purpose however is to allow the engine to be OS agnostic, by performing a task identically across windows and Unix.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-8" parent="Rupf-1fVi9H6Zibw66AW-23" style="swimlane;startSize=23;" value="Thread Scheduler" vertex="1">
          <mxGeometry height="200" width="200" x="600" y="80" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-9" parent="-NolNCKCxvoOFp3M2r7I-8" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;The thread scheduler is responsible to properly schedule jobs across all available threads.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Any part of the engine may at any time send a Job to the scheduler from any thread, and the scheduler will be able to handle it responsibly.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-31" edge="1" parent="1" source="-NolNCKCxvoOFp3M2r7I-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" target="Rupf-1fVi9H6Zibw66AW-23">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="QZozGhfnKPgpjbq-TObu-11" edge="1" parent="1" source="-NolNCKCxvoOFp3M2r7I-10" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="940" y="495" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-10" parent="1" style="swimlane;startSize=50;" value="Deep Core Handlers" vertex="1">
          <mxGeometry height="290" width="800" x="25" y="350" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-16" parent="-NolNCKCxvoOFp3M2r7I-10" style="swimlane;" value="Render Handler" vertex="1">
          <mxGeometry height="200" width="200" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-129" parent="-NolNCKCxvoOFp3M2r7I-16" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;The render handler is meant to allow game components to easily render objects by just simply passing in a render mission.&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;The render handler also performs automatic draw call optimization.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="182" x="8" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-17" parent="-NolNCKCxvoOFp3M2r7I-10" style="swimlane;" value="Input Handler" vertex="1">
          <mxGeometry height="200" width="200" x="200" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-130" parent="-NolNCKCxvoOFp3M2r7I-17" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;div&gt;The Input handler is the primary way to get input. It provides a rich access to input information.&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Controllers are also supported.&lt;/div&gt;" vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-18" parent="-NolNCKCxvoOFp3M2r7I-10" style="swimlane;" value="Audio Handler" vertex="1">
          <mxGeometry height="200" width="200" x="400" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-131" parent="-NolNCKCxvoOFp3M2r7I-18" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The Audio handler is not fleshed out at all, but you can pass in a sound and it wall play it. Yeah that&#39;s all." vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-19" parent="-NolNCKCxvoOFp3M2r7I-10" style="swimlane;startSize=23;" value="Job Handler" vertex="1">
          <mxGeometry height="200" width="200" x="600" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-132" parent="-NolNCKCxvoOFp3M2r7I-19" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="At the current moment, this doesn&#39;t work. This will handle batching of jobs to allow for easy multi threading." vertex="1">
          <mxGeometry height="170" width="180" x="10" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-28" parent="-NolNCKCxvoOFp3M2r7I-10" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The deep core handlers directly interface the system abstractions to provide an easy to use framework to components. These are directly communicating with the system abstractions to achieve their goals." vertex="1">
          <mxGeometry height="40" width="785" x="8" y="50" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-24" parent="1" style="swimlane;startSize=50;" value="High level Core Handlers" vertex="1">
          <mxGeometry height="290" width="606" x="124" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-22" parent="-NolNCKCxvoOFp3M2r7I-24" style="swimlane;" value="Widget Handler" vertex="1">
          <mxGeometry height="200" width="200" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-145" parent="-NolNCKCxvoOFp3M2r7I-22" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The widget handler displays GUI elements." vertex="1">
          <mxGeometry height="170" width="184" x="6" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-23" parent="-NolNCKCxvoOFp3M2r7I-24" style="swimlane;" value="RNG Handler" vertex="1">
          <mxGeometry height="200" width="200" x="200" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-146" parent="-NolNCKCxvoOFp3M2r7I-23" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The rng handler generates random numbers on demand." vertex="1">
          <mxGeometry height="170" width="179" x="11" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-20" parent="-NolNCKCxvoOFp3M2r7I-24" style="swimlane;" value="Physics Handler" vertex="1">
          <mxGeometry height="200" width="200" x="400" y="90" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-147" parent="-NolNCKCxvoOFp3M2r7I-20" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The physics handler simulates physical bodies inside the game." vertex="1">
          <mxGeometry height="170" width="184" x="8" y="30" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-128" parent="-NolNCKCxvoOFp3M2r7I-24" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="The high level core handlers are meant to implement basic/common game play systems, rather than engine functionality. They do not talk to system abstractions." vertex="1">
          <mxGeometry height="40" width="584" x="6" y="50" as="geometry" />
        </mxCell>
        <mxCell id="-NolNCKCxvoOFp3M2r7I-27" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="This is sort of like the driver of the engine. This layer directly accesses key and deep parts of the computer and is responsible that everything else runs identically across all other system configurations." vertex="1">
          <mxGeometry height="40" width="790" x="30" y="720" as="geometry" />
        </mxCell>
